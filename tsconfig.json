{
  "include": ["./src/**/*.ts", "./examples/**/*.ts"],
  "exclude": ["./src/**/__tests__", "./build/**"],
  "compilerOptions": {
    "lib": ["es2020", "DOM"],
    "module": "commonjs",
    "target": "es2020",

    "rootDir": ".",
    "outDir": "build",

    "strict": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true
  }
}
